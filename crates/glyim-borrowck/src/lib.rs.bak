//! Borrow checker with full dataflow and proper last-use of borrow destinations.

use glyim_diag::{GlyimDiagnostic, MultiSpan};
use glyim_mir::{
    BasicBlockIdx, Body, BorrowKind, LocalIdx, Operand, Rvalue, StatementKind, TerminatorKind,
};
use glyim_span::Span;
use glyim_type::TyCtx;
use std::collections::{HashMap, HashSet};
use std::sync::atomic::{AtomicBool, Ordering};

static DEBUG: AtomicBool = AtomicBool::new(false);

#[derive(Clone, Debug)]
pub struct BorrowckResult {
    pub errors: Vec<GlyimDiagnostic>,
}

pub trait BorrowckCtx {
    fn ty_ctx(&self) -> &TyCtx;
    fn local_decl(&self, local: LocalIdx) -> &glyim_mir::LocalDecl;
    fn is_copy(&self, ty: glyim_type::Ty) -> bool;
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
struct BorrowIdx(usize);

#[derive(Debug, Clone)]
struct BorrowData {
    source: LocalIdx,          // the borrowed local (e.g., `x`)
    dest: LocalIdx,            // the local where the borrow is stored (e.g., `_1`)
    kind: BorrowKind,
    span: Span,
    issued_at_stmt: usize,     // statement index within its block
    issued_at_block: usize,    // block index
    last_use_stmt: Option<usize>,
    last_use_block: Option<usize>,
}

struct BorrowSet {
    borrows: Vec<BorrowData>,
    by_dest: HashMap<LocalIdx, Vec<BorrowIdx>>,
    by_source: HashMap<LocalIdx, Vec<BorrowIdx>>,
}

impl BorrowSet {
    fn new() -> Self {
        Self {
            borrows: Vec::new(),
            by_dest: HashMap::new(),
            by_source: HashMap::new(),
        }
    }

    fn add_borrow(&mut self, dest: LocalIdx, source: LocalIdx, kind: BorrowKind, span: Span, block: usize, stmt: usize) -> BorrowIdx {
        let idx = BorrowIdx(self.borrows.len());
        self.borrows.push(BorrowData {
            source,
            dest,
            kind,
            span,
            issued_at_stmt: stmt,
            issued_at_block: block,
            last_use_stmt: None,
            last_use_block: None,
        });
        self.by_dest.entry(dest).or_default().push(idx);
        self.by_source.entry(source).or_default().push(idx);
        idx
    }

    fn set_last_use(&mut self, idx: BorrowIdx, block: usize, stmt: usize) {
        if let Some(b) = self.borrows.get_mut(idx.0) {
            b.last_use_block = Some(block);
            b.last_use_stmt = Some(stmt);
        }
    }
}

struct BorrowDataflow {
    borrow_set: BorrowSet,
    block_in: Vec<HashSet<BorrowIdx>>,
    block_out: Vec<HashSet<BorrowIdx>>,
    // For each block, a set of (local, last use statement index) for destinations
    dest_last_use: Vec<HashMap<LocalIdx, usize>>,
}

impl BorrowDataflow {
    fn new(num_blocks: usize) -> Self {
        Self {
            borrow_set: BorrowSet::new(),
            block_in: vec![HashSet::new(); num_blocks],
            block_out: vec![HashSet::new(); num_blocks],
            dest_last_use: vec![HashMap::new(); num_blocks],
        }
    }

    // Collect all borrows and compute last use of their destinations (backward liveness)
    fn collect_borrows_and_last_uses(&mut self, body: &Body) {
        // First collect all borrows and record their issue points
        for (bb_idx, block) in body.basic_blocks.iter_enumerated() {
            let bb = bb_idx.to_raw() as usize;
            for (stmt_idx, stmt) in block.statements.iter().enumerate() {
                if let StatementKind::Assign(place, Rvalue::Ref(source_place, kind)) = &stmt.kind {
                    if place.projection.is_empty() && source_place.projection.is_empty() {
                        let idx = self.borrow_set.add_borrow(
                            place.local, source_place.local, *kind, stmt.source_info.span,
                            bb, stmt_idx
                        );
                        if DEBUG.load(Ordering::Relaxed) {
                            eprintln!("[BORROW] created {:?}: dest={}, src={}, kind={:?} at block={}, stmt={}",
                                      idx, place.local.to_raw(), source_place.local.to_raw(), kind, bb, stmt_idx);
                        }
                    }
                }
            }
        }

        // Compute last use of each borrow's destination local (backward dataflow)
        // For simplicity, we compute per-block last use (where the local is read)
        for (bb_idx, block) in body.basic_blocks.iter_enumerated() {
            let bb = bb_idx.to_raw() as usize;
            let mut last_use = HashMap::new();
            // forward scan to record the last read of each local in this block
            for (stmt_idx, stmt) in block.statements.iter().enumerate() {
                for local in self.reads_of_stmt(stmt) {
                    last_use.insert(local, stmt_idx);
                }
            }
            for local in self.reads_of_terminator(&block.terminator) {
                let idx = block.statements.len();
                last_use.insert(local, idx);
            }
            self.dest_last_use[bb] = last_use;
        }

        // Now for each borrow, find its last use (the last statement where its destination is read)
        for idx in 0..self.borrow_set.borrows.len() {
            let borrow = &self.borrow_set.borrows[idx];
            let dest = borrow.dest;
            // We need the global last use across all blocks; we'll approximate with block-local last use
            // This is a simplification; a full backward analysis would be better.
            // For now, we'll use the last use in the same block as the borrow (if any) or assume it lives to the end.
            if let Some(&last_stmt) = self.dest_last_use[borrow.issued_at_block].get(&dest) {
                if last_stmt >= borrow.issued_at_stmt {
                    let issue_block = borrow.issued_at_block;
                self.borrow_set.set_last_use(BorrowIdx(idx), issue_block, last_stmt);
                    if DEBUG.load(Ordering::Relaxed) {
                        eprintln!("[LASTUSE] Borrow {:?} last use at block={}, stmt={}",
                                  BorrowIdx(idx), borrow.issued_at_block, last_stmt);
                    }
                } else {
                    // last use before issue - not possible normally, but fallback: expire at end of block
                    self.borrow_set.set_last_use(BorrowIdx(idx), borrow.issued_at_block, borrow.issued_at_stmt);
                }
            } else {
                // No read in this block; assume it lives to the end of block? Actually it may die at end.
                // We'll assume it dies at the end of the block (expires). This is conservative.
                // Set last use to the last statement in the block (or terminator)
                let block_len = body.basic_blocks[BasicBlockIdx::from_raw(borrow.issued_at_block as u32)].statements.len();
                self.borrow_set.set_last_use(BorrowIdx(idx), issue_block, block_len);
                if DEBUG.load(Ordering::Relaxed) {
                    eprintln!("[LASTUSE] Borrow {:?} no read in its block, setting to end of block (stmt={})",
                              BorrowIdx(idx), block_len);
                }
            }
        }
    }

    fn reads_of_stmt(&self, stmt: &glyim_mir::Statement) -> HashSet<LocalIdx> {
        let mut reads = HashSet::new();
        match &stmt.kind {
            StatementKind::Assign(_, rvalue) => self.reads_of_rvalue(rvalue, &mut reads),
            _ => {}
        }
        reads
    }

    fn reads_of_rvalue(&self, rvalue: &Rvalue, reads: &mut HashSet<LocalIdx>) {
        match rvalue {
            Rvalue::Use(op) => self.reads_of_operand(op, reads),
            Rvalue::BinaryOp(_, ops) => {
                self.reads_of_operand(&ops.0, reads);
                self.reads_of_operand(&ops.1, reads);
            }
            Rvalue::UnaryOp(_, op) => self.reads_of_operand(op, reads),
            Rvalue::Ref(place, _) => {
                if place.projection.is_empty() {
                    reads.insert(place.local);
                }
            }
            Rvalue::Aggregate(_, ops) => {
                for op in ops {
                    self.reads_of_operand(op, reads);
                }
            }
            Rvalue::Discriminant(place) | Rvalue::Len(place) => {
                if place.projection.is_empty() {
                    reads.insert(place.local);
                }
            }
            Rvalue::Cast(_, op, _) => self.reads_of_operand(op, reads),
            Rvalue::Repeat(op, _) => self.reads_of_operand(op, reads),
        }
    }

    fn reads_of_operand(&self, op: &Operand, reads: &mut HashSet<LocalIdx>) {
        match op {
            Operand::Copy(place) | Operand::Move(place) => {
                if place.projection.is_empty() {
                    reads.insert(place.local);
                }
            }
            _ => {}
        }
    }

    fn reads_of_terminator(&self, term: &glyim_mir::Terminator) -> HashSet<LocalIdx> {
        let mut reads = HashSet::new();
        match &term.kind {
            TerminatorKind::Call { func, args, .. } => {
                self.reads_of_operand(func, &mut reads);
                for arg in args {
                    self.reads_of_operand(arg, &mut reads);
                }
            }
            TerminatorKind::SwitchInt { discr, .. } => self.reads_of_operand(discr, &mut reads),
            TerminatorKind::Assert { cond, .. } => self.reads_of_operand(cond, &mut reads),
            _ => {}
        }
        reads
    }

    // Gen set: borrows whose destination is written in this statement (the borrow itself)
    fn generated_set(&self, stmt: &glyim_mir::Statement, stmt_idx: usize, block: usize) -> HashSet<BorrowIdx> {
        let mut generated = HashSet::new();
        if let StatementKind::Assign(place, Rvalue::Ref(_, _)) = &stmt.kind {
            if place.projection.is_empty() {
                if let Some(borrows) = self.borrow_set.by_dest.get(&place.local) {
                    for &bidx in borrows {
                        let b = &self.borrow_set.borrows[bidx.0];
                        if b.issued_at_block == block && b.issued_at_stmt == stmt_idx {
                            generated.insert(bidx);
                        }
                    }
                }
            }
        }
        generated
    }

    // Kill set: borrows whose destination is overwritten, or whose last use has passed
    fn killed_set(&self, stmt: &glyim_mir::Statement, stmt_idx: usize, block: usize) -> HashSet<BorrowIdx> {
        let mut killed = HashSet::new();
        // Overwrite of the destination local kills the borrow
        if let StatementKind::Assign(place, _) = &stmt.kind {
            if place.projection.is_empty() {
                if let Some(borrows) = self.borrow_set.by_dest.get(&place.local) {
                    for &bidx in borrows {
                        killed.insert(bidx);
                    }
                }
            }
        }
        // Borrows whose last use is this statement (i.e., they expire)
        for (idx, borrow) in self.borrow_set.borrows.iter().enumerate() {
            if borrow.last_use_block == Some(block) && borrow.last_use_stmt == Some(stmt_idx) {
                killed.insert(BorrowIdx(idx));
            }
        }
        killed
    }

    fn transfer(&self, in_set: &HashSet<BorrowIdx>, block: &glyim_mir::BasicBlockData, block_idx: usize) -> HashSet<BorrowIdx> {
        let mut out = in_set.clone();
        for (idx, stmt) in block.statements.iter().enumerate() {
            let killed = self.killed_set(stmt, idx, block_idx);
            let generated = self.generated_set(stmt, idx, block_idx);
            let killed_for_debug = &killed;
            let generated_for_debug = &generated;
            for k in killed {
                out.remove(&k);
            }
            out.extend(generated);
            if DEBUG.load(Ordering::Relaxed) {
                eprintln!("[TRANSFER] block={}, stmt={}: in={:?}, killed={:?}, gen={:?}, out={:?}",
                          block_idx, idx, in_set, killed_for_debug, generated_for_debug, out);
            }
        }
        out
    }

    fn run_analysis(&mut self, body: &Body) {
        let n_blocks = body.basic_blocks.len();
        let mut changed = true;
        while changed {
            changed = false;
            for bb in 0..n_blocks {
                let block = &body.basic_blocks[BasicBlockIdx::from_raw(bb as u32)];
                let in_state = self.block_in[bb].clone();
                let out_state = self.transfer(&in_state, block, bb);
                if out_state != self.block_out[bb] {
                    self.block_out[bb] = out_state.clone();
                    changed = true;
                }
                let succs = self.terminator_successors(&block.terminator);
                for succ in succs {
                    let succ_idx = succ.to_raw() as usize;
                    if succ_idx < n_blocks {
                        let new_in = self.merge(&self.block_in[succ_idx], &out_state);
                        if new_in != self.block_in[succ_idx] {
                            self.block_in[succ_idx] = new_in;
                            changed = true;
                        }
                    }
                }
            }
        }
    }

    fn terminator_successors(&self, term: &glyim_mir::Terminator) -> Vec<BasicBlockIdx> {
        match &term.kind {
            TerminatorKind::Goto { target } => vec![*target],
            TerminatorKind::SwitchInt { targets, .. } => {
                let mut s: Vec<_> = targets.iter().map(|(_, t)| t).collect();
                s.push(targets.otherwise());
                s
            }
            TerminatorKind::Call { target, cleanup, .. } => {
                let mut s = Vec::new();
                if let Some(t) = target {
                    s.push(*t);
                }
                if let Some(c) = cleanup {
                    s.push(*c);
                }
                s
            }
            TerminatorKind::Assert { target, cleanup, .. } => {
                let mut s = vec![*target];
                if let Some(c) = cleanup {
                    s.push(*c);
                }
                s
            }
            TerminatorKind::Drop { target, cleanup, .. } => {
                let mut s = vec![*target];
                if let Some(c) = cleanup {
                    s.push(*c);
                }
                s
            }
            _ => vec![],
        }
    }

    fn merge(&self, a: &HashSet<BorrowIdx>, b: &HashSet<BorrowIdx>) -> HashSet<BorrowIdx> {
        let mut result = a.clone();
        result.extend(b);
        result
    }

    fn check_conflicts(&self, active: &HashSet<BorrowIdx>, stmt: &glyim_mir::Statement) -> Vec<GlyimDiagnostic> {
        let mut errors = Vec::new();
        match &stmt.kind {
            StatementKind::Assign(place, rvalue) => {
                // Check write to borrowed source (if destination is a borrow source)
                if place.projection.is_empty() {
                    if let Some(borrows) = self.borrow_set.by_source.get(&place.local) {
                        for &bidx in borrows {
                            if active.contains(&bidx) {
                                let b = &self.borrow_set.borrows[bidx.0];
                                let conflict = match b.kind {
                                    BorrowKind::Shared => false,
                                    BorrowKind::Mut { .. } | BorrowKind::Unique => true,
                                };
                                if conflict {
                                    errors.push(
                                        GlyimDiagnostic::borrow_error(
                                            stmt.source_info.span,
                                            format!("cannot assign to `{}` because it is borrowed", place.local.to_raw()),
                                        )
                                        .with_sub(glyim_diag::SubDiagnostic {
                                            severity: glyim_diag::DiagSeverity::Note,
                                            message: format!("{} borrow occurs here", Self::borrow_kind_str(&b.kind)),
                                            span: Some(MultiSpan::from_span(b.span)),
                                        }),
                                    );
                                    break;
                                }
                            }
                        }
                    }
                }

                // Check new borrow conflicts with existing borrows on the same source
                if let Rvalue::Ref(source, new_kind) = rvalue {
                    if source.projection.is_empty() {
                        if let Some(borrows) = self.borrow_set.by_source.get(&source.local) {
                            for &bidx in borrows {
                                if active.contains(&bidx) {
                                    let existing = &self.borrow_set.borrows[bidx.0];
                                    let conflict = match (existing.kind, new_kind) {
                                        (BorrowKind::Shared, BorrowKind::Shared) => false,
                                        (BorrowKind::Mut { .. }, _) | (_, BorrowKind::Mut { .. }) => true,
                                        (BorrowKind::Unique, _) | (_, BorrowKind::Unique) => true,
                                    };
                                    if conflict {
                                        errors.push(
                                            GlyimDiagnostic::borrow_error(
                                                stmt.source_info.span,
                                                format!("cannot borrow `{}` as {} because it is already borrowed as {}",
                                                    source.local.to_raw(),
                                                    Self::borrow_kind_str(new_kind),
                                                    Self::borrow_kind_str(&existing.kind)),
                                            )
                                            .with_sub(glyim_diag::SubDiagnostic {
                                                severity: glyim_diag::DiagSeverity::Note,
                                                message: "previous borrow occurs here".to_string(),
                                                span: Some(MultiSpan::from_span(existing.span)),
                                            }),
                                        );
                                        break;
                                    }
                                }
                            }
                        }
                    }
                }

                // Check use of a borrowed value (if it's a use of a borrow destination)
                if let Rvalue::Use(Operand::Copy(place) | Operand::Move(place)) = rvalue {
                    if place.projection.is_empty() {
                        if let Some(borrows) = self.borrow_set.by_dest.get(&place.local) {
                            for &bidx in borrows {
                                if active.contains(&bidx) {
                                    let b = &self.borrow_set.borrows[bidx.0];
                                    let conflict = match b.kind {
                                        BorrowKind::Shared => false,
                                        BorrowKind::Mut { .. } | BorrowKind::Unique => true,
                                    };
                                    if conflict {
                                        errors.push(
                                            GlyimDiagnostic::borrow_error(
                                                stmt.source_info.span,
                                                format!("cannot use `{}` because it is mutably borrowed", place.local.to_raw()),
                                            )
                                            .with_sub(glyim_diag::SubDiagnostic {
                                                severity: glyim_diag::DiagSeverity::Note,
                                                message: "borrow occurs here".to_string(),
                                                span: Some(MultiSpan::from_span(b.span)),
                                            }),
                                        );
                                        break;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            _ => {}
        }
        errors
    }

    fn borrow_kind_str(kind: &BorrowKind) -> &'static str {
        match kind {
            BorrowKind::Shared => "shared",
            BorrowKind::Mut { .. } => "mutable",
            BorrowKind::Unique => "unique",
        }
    }
}

pub fn check_borrows(_ctx: &dyn BorrowckCtx, body: &Body) -> BorrowckResult {
    // Enable debug if RUST_LOG=debug or GLYIM_BORROW_DEBUG set
    if std::env::var("GLYIM_BORROW_DEBUG").is_ok() {
        DEBUG.store(true, Ordering::Relaxed);
    }

    let n_blocks = body.basic_blocks.len();
    let mut dataflow = BorrowDataflow::new(n_blocks);
    dataflow.collect_borrows_and_last_uses(body);
    dataflow.block_in[0] = HashSet::new();
    dataflow.run_analysis(body);

    let mut errors = Vec::new();
    for bb in 0..n_blocks {
        let block = &body.basic_blocks[BasicBlockIdx::from_raw(bb as u32)];
        let mut active = dataflow.block_in[bb].clone();
        if DEBUG.load(Ordering::Relaxed) {
            eprintln!("[CHECK] Block {} initial active: {:?}", bb, active.iter().map(|i| i.0).collect::<Vec<_>>());
        }
        for (idx, stmt) in block.statements.iter().enumerate() {
            errors.extend(dataflow.check_conflicts(&active, stmt));
            let killed = dataflow.killed_set(stmt, idx, bb);
            let generated = dataflow.generated_set(stmt, idx, bb);
            if DEBUG.load(Ordering::Relaxed) {
                eprintln!("[CHECK] Block {} stmt {}: before active={:?}, kill={:?}, gen={:?}",
                          bb, idx, active.iter().map(|i| i.0).collect::<Vec<_>>(),
                          killed.iter().map(|i| i.0).collect::<Vec<_>>(),
                          generated.iter().map(|i| i.0).collect::<Vec<_>>());
            }
            for k in killed {
                active.remove(&k);
            }
            active.extend(generated);
        }
    }
    BorrowckResult { errors }
}

#[cfg(test)]
mod tests;
