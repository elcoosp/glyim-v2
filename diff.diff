+    BasicBlockData, Body, LocalDecl, LocalIdx, MirConst, MirConstKind, Operand, Place, Rvalue,
+    SourceInfo, Statement, StatementKind, Terminator, TerminatorKind,
+};
+use glyim_span::{ByteIdx, FileId, Span};
+use glyim_type::{TyCtxMut, TyKind};
+
+fn build_len_body(ctx: &mut TyCtxMut) -> Body {
+    let i32_ty = ctx.mk_ty(TyKind::Int(IntTy::I32));
+    let usize_ty = ctx.mk_ty(TyKind::Uint(UintTy::Usize));
+    let count = glyim_type::Const {
+        kind: glyim_type::ConstKind::Uint(5),
+        ty: usize_ty,
+    };
+    let array_ty = ctx.mk_ty(TyKind::Array(i32_ty, count));
+
+    let mut locals: IndexVec<LocalIdx, LocalDecl> = IndexVec::new();
+    locals.push(LocalDecl {
+        ty: usize_ty,
+        mutability: Mutability::Not,
+        source_info: SourceInfo::new(Span::new(
+            FileId::BOGUS,
+            ByteIdx::ZERO,
+            ByteIdx::ZERO,
+            glyim_span::SyntaxContext::ROOT,
+        )),
+    });
+    locals.push(LocalDecl {
+        ty: array_ty,
+        mutability: Mutability::Not,
+        source_info: SourceInfo::new(Span::DUMMY),
+    });
+
+    let mut basic_blocks: IndexVec<glyim_mir::BasicBlockIdx, BasicBlockData> = IndexVec::new();
+
+    let zero_elem = MirConst {
+        kind: MirConstKind::Int(0),
+        ty: i32_ty,
+        span: Span::DUMMY,
+    };
+    let stmt_init_array = Statement {
+        kind: StatementKind::Assign(
+            Place::new(LocalIdx::from_raw(1)),
+            Rvalue::Aggregate(
+                glyim_mir::AggregateKind::Array(i32_ty),
+                vec![
+                    Operand::Constant(zero_elem.clone()),
+                    Operand::Constant(zero_elem.clone()),
+                    Operand::Constant(zero_elem.clone()),
+                    Operand::Constant(zero_elem.clone()),
+                    Operand::Constant(zero_elem),
+                ],
+            ),
+        ),
+        source_info: SourceInfo::new(Span::DUMMY),
+    };
+    let stmt_len = Statement {
+        kind: StatementKind::Assign(
+            Place::new(LocalIdx::from_raw(0)),
+            Rvalue::Len(Place::new(LocalIdx::from_raw(1))),
+        ),
+        source_info: SourceInfo::new(Span::DUMMY),
+    };
+
+    let mut bb0 = BasicBlockData::new(Terminator {
+        kind: TerminatorKind::Return,
+        source_info: SourceInfo::new(Span::DUMMY),
+    });
+    bb0.statements.push(stmt_init_array);
+    bb0.statements.push(stmt_len);
+    basic_blocks.push(bb0);
+
+    Body {
+        owner: DefId::new(CrateId::from_raw(0), LocalDefId::from_raw(2)),
+        basic_blocks,
+        locals,
+        arg_count: 0,
+        return_ty: usize_ty,
+        span: Span::DUMMY,
+        var_debug_info: Vec::new(),
+    }
+}
+
+#[test]
+fn u05_t03_len_of_array_returns_correct_length() {
+    let mut ctx = TyCtxMut::new(Interner::default());
+    let body = build_len_body(&mut ctx);
+    let frozen = ctx.freeze();
+
+    let backend = LlvmBackend::new().with_ty_ctx(frozen);
+    let ir = backend
+        .generate_ir(&body)
+        .expect("generate_ir should succeed");
+
+    assert!(
+        ir.contains("5"),
+        "IR should contain the constant 5 for array length, got:\n{}",
+        ir
+    );
+    assert!(
+        ir.contains("[5 x i32]"),
+        "IR should contain array type [5 x i32], got:\n{}",
+        ir
+    );
+}
