+    assert!(
+        ir.contains("[4 x i32]"),
+        "IR should contain array type [4 x i32] from repeat, got:\n{}",
+        ir
+    );
+    assert!(
+        ir.contains("insertvalue"),
+        "IR should contain insertvalue for repeat construction, got:\n{}",
+        ir
+    );
+}
